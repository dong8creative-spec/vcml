JWT_SECRET=여기에_강력한_랜덤_문자열_입력
PORT=3300

KAKAO_CLIENT_ID=카카오_REST_API_키
KAKAO_REDIRECT_URI=https://vcml.kr/api/auth/kakao/callback
# 카카오 개발자 콘솔 > 앱 설정 > 회원가입 URL: https://vcml.kr/signup.html

GOOGLE_CLIENT_ID=Google_OAuth_클라이언트_ID
GOOGLE_CLIENT_SECRET=Google_OAuth_클라이언트_시크릿
GOOGLE_REDIRECT_URI=https://vcml.kr/api/auth/google/callback

# 베타 기간 Google 간편 로그인 (0이면 이메일 가입 UI도 노출)
AUTH_BETA_MODE=1
# 베타 중 카카오 로그인 허용 (1=허용, 0=비활성)
# KAKAO_LOGIN_ENABLED=1

# 관리자 페이지 접근 허용 이메일 (쉼표 구분, role=admin 계정만 해당)
# 미설정 시 role=admin 이면 모두 접근 가능. 설정 시 목록에 있는 admin 이메일만 접근.
ADMIN_EMAILS=dong8creative@gmail.com

# 실서비스 도메인 — 미설정 시 https://vcml.kr 사용.
# sitemap.xml, 강의 상세 canonical/OG/JSON-LD, 타닥싱크(TadakSync) 앱 연동 URL이
# 전부 이 값 하나를 따라간다(server.js, routes/subtitle.js). 도메인을 바꿀 때 이 한 줄만 수정.
# SITE_ORIGIN=https://vcml.kr
# SUBTITLE_TOOL_STORAGE_PATH=subtitle-tool/TadakSync.zip

# 결제: 당분간 네이버 스마트스토어. 사이트 PG는 카카오페이·KG이니시스만 예정 (토스 미사용)
# KAKAO_PAY_* / INICIS_* 키는 연동 시 추가

# SMS (카카오 알림톡 — 운영 시 입력)
ALIMTALK_API_KEY=
ALIMTALK_API_SECRET=
ALIMTALK_PFID=
ALIMTALK_TMPL_COUPON=
ALIMTALK_TMPL_LIVE=
SMS_SENDER=

# 로그인 기록 → Google Sheets (관리자 > 로그인 기록)
# 1) GCP 서비스 계정 생성 → Sheets API 활성화 → 스프레드시트에 서비스 계정 이메일 편집자 권한
# 2) 서비스 계정 JSON 전체를 한 줄로 GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON 에 넣기
# GOOGLE_SHEETS_SPREADSHEET_ID=스프레드시트_ID
# GOOGLE_SHEETS_LOGIN_LOG_TAB=로그인기록
# LOGIN_LOG_SHEETS_CRON=1
# LOGIN_LOG_SHEETS_CRON_HOUR_KST=1
# LOGIN_LOG_SHEETS_CRON_MINUTE_KST=5
# CRON_SECRET=외부_cron_호출_시크릿

NODE_ENV=production
