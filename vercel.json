{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/public/$1",
      "headers": { "Cache-Control": "private, no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/",
      "dest": "/public/index.html",
      "headers": { "Cache-Control": "private, no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/favicon\\.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
